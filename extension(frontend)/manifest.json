{
  "manifest_version": 3,
  "name": "Leonidas",
  "version": "1.0",
  "description": "Analyze phishing and misdirecting links before falling prey to them with smart AIML powered detection.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://*.onrender.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  }
}